# ~/.cloudflared/config.yml 예시 (실제 파일은 항상 홈: ~/.cloudflared/ — 레포에 복사·커밋 금지)
# ./setup 가 Tunnel 단계에서 호스트·포트에 맞게 생성하거나 안내합니다.
#
# 중요: service 는 반드시 이 맥의 루프백만 지정합니다.
#   올바름: http://127.0.0.1:8080
#   금지:   http://공인IP:8080  (cloudflared 가 말고 다른 경로로 붙이려는 설정과 혼동하지 마세요)
# 터널 에이전트(cloudflared)가 이 맥에서 돌아가면, 방문자 → Cloudflare → 터널 → 127.0.0.1 로 연결됩니다.
#
# tunnel: <터널_UUID>
# credentials-file: /Users/본인/.cloudflared/<UUID>.json
#
# ingress:
#   - hostname: app.example.com
#     service: http://127.0.0.1:8080
#   - service: http_status:404

tunnel: REPLACE_TUNNEL_UUID
credentials-file: REPLACE_CREDENTIALS_PATH

ingress:
  - hostname: REPLACE_HOSTNAME
    service: http://127.0.0.1:8080
  - service: http_status:404
