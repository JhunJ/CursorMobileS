<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.cursor.agent.worker</string>
	<key>ProgramArguments</key>
	<array>
		<string>__AGENT_BIN__</string>
		<string>worker</string>
		<string>start</string>
